# Per-company operational artifacts — ENTIRELY operator-private.
# Every operator's `companies/<slug>/` (product config, drafts,
# exemplars, …) is local runtime state. Nothing under this tree
# is source-controlled; the directory is created on first use.
# Leading slash anchors to the repo root so it does NOT also ignore
# unrelated `companies/` dirs elsewhere (e.g. web/src/components/companies/).
/companies/

# Agent-generated knowledge (instance-specific, except base templates)
knowledge/*
!knowledge/system/
!knowledge/organization-roles/

# Node.js bridge plugins
bridge/*/dist/
bridge/*/node_modules/
bridge/*/data/

# Web dashboard
web/node_modules/
web/dist/
# TypeScript incremental build cache — regenerated on every build,
# pure churn in git status.
*.tsbuildinfo

# uv
.python-version

